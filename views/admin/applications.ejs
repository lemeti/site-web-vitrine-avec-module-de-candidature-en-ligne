<%- include('../partials/admin-start') %>

<% const exportParams = new URLSearchParams(); %>
<% Object.entries(filters).forEach(([key, value]) => { if (value) exportParams.set(key, value); }); %>

<section class="admin-title">
  <div>
    <p class="eyebrow">Traitement administratif</p>
    <h1>Candidatures</h1>
  </div>
  <a class="button button--secondary" href="/admin/candidatures/export.csv?<%= exportParams.toString() %>">Exporter CSV</a>
</section>

<% const selected = (name, value) => String(filters[name] || '') === String(value) ? 'selected' : ''; %>

<form class="filter-bar" action="/admin/candidatures" method="get">
  <input name="search" placeholder="Reference, nom, e-mail..." value="<%= filters.search %>">
  <select name="cycle_id">
    <option value="">Tous les cycles</option>
    <% cycles.forEach((cycle) => { %>
      <option value="<%= cycle.id %>" <%= selected('cycle_id', cycle.id) %>><%= cycle.name %></option>
    <% }) %>
  </select>
  <select name="program_id">
    <option value="">Toutes les filieres</option>
    <% programs.forEach((program) => { %>
      <option value="<%= program.id %>" <%= selected('program_id', program.id) %>><%= program.code %></option>
    <% }) %>
  </select>
  <select name="center_id">
    <option value="">Tous les centres</option>
    <% centers.forEach((center) => { %>
      <option value="<%= center.id %>" <%= selected('center_id', center.id) %>><%= center.name %></option>
    <% }) %>
  </select>
  <select name="status">
    <option value="">Tous les statuts</option>
    <% statuses.forEach((status) => { %>
      <option value="<%= status.value %>" <%= selected('status', status.value) %>><%= status.label %></option>
    <% }) %>
  </select>
  <button class="button" type="submit">Filtrer</button>
</form>

<section class="admin-panel">
  <% if (!applications.length) { %>
    <p class="empty-state">Aucun dossier ne correspond aux filtres.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Reference</th>
            <th>Candidat</th>
            <th>Cycle</th>
            <th>Filiere</th>
            <th>Centre</th>
            <th>Statut</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% applications.forEach((application) => { %>
            <tr>
              <td><a href="/admin/candidatures/<%= application.id %>"><%= application.reference_number %></a></td>
              <td><%= application.last_name %> <%= application.first_name %></td>
              <td><%= application.cycle_name %></td>
              <td><%= application.program_code %></td>
              <td><%= application.center_name %></td>
              <td><span class="status status--<%= application.status %>"><%= statusLabel(application.status) %></span></td>
              <td><%= formatDateTime(application.submitted_at) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('../partials/admin-end') %>
