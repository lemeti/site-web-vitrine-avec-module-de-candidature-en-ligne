<%- include('../partials/admin-start') %>

<section class="admin-title">
  <div>
    <a class="back-link" href="/admin/actualites">Retour aux actualites</a>
    <p class="eyebrow">Actualite</p>
    <h1><%= item.id ? 'Modifier' : 'Nouvelle actualite' %></h1>
  </div>
</section>

<section class="admin-panel">
  <form action="<%= action %>" method="post" class="stack-form">
    <label>
      <span>Titre</span>
      <input name="title" value="<%= item.title || '' %>" required>
    </label>
    <label>
      <span>Resume</span>
      <textarea name="excerpt" rows="3" required><%= item.excerpt || '' %></textarea>
    </label>
    <label>
      <span>Contenu</span>
      <textarea name="body" rows="9" required><%= item.body || '' %></textarea>
    </label>
    <label>
      <span>Date de publication</span>
      <input type="date" name="published_at" value="<%= item.published_at || new Date().toISOString().slice(0, 10) %>">
    </label>
    <label class="checkbox-line">
      <input type="checkbox" name="is_published" <%= item.id ? (item.is_published ? 'checked' : '') : 'checked' %>>
      <span>Publier sur le site</span>
    </label>
    <button class="button" type="submit">Enregistrer</button>
  </form>
</section>

<%- include('../partials/admin-end') %>
