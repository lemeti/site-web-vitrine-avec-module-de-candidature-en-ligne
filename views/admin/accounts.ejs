<%- include('../partials/admin-start') %>

<section class="admin-title">
  <div>
    <p class="eyebrow">Securite</p>
    <h1>Comptes administrateurs</h1>
  </div>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2>Comptes existants</h2>
    <div class="compact-list">
      <% admins.forEach((account) => { %>
        <div class="list-row">
          <div>
            <strong><%= account.name %></strong>
            <span><%= account.email %> - <%= account.role %></span>
          </div>
          <% if (account.id !== admin.id) { %>
            <form action="/admin/comptes/<%= account.id %>/supprimer" method="post" data-confirm="Supprimer ce compte ?">
              <button class="link-button" type="submit">Supprimer</button>
            </form>
          <% } %>
        </div>
      <% }) %>
    </div>
  </article>

  <article class="admin-panel">
    <h2>Nouveau compte</h2>
    <form action="/admin/comptes" method="post" class="stack-form">
      <label>
        <span>Nom</span>
        <input name="name" required>
      </label>
      <label>
        <span>E-mail</span>
        <input type="email" name="email" required>
      </label>
      <label>
        <span>Mot de passe</span>
        <input type="password" name="password" minlength="8" required>
      </label>
      <label>
        <span>Role</span>
        <select name="role">
          <option value="admin">Administrateur</option>
          <option value="super_admin">Super administrateur</option>
        </select>
      </label>
      <button class="button" type="submit">Creer le compte</button>
    </form>
  </article>
</section>

<%- include('../partials/admin-end') %>
