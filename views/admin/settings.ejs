<%- include('../partials/admin-start') %>

<section class="admin-title">
  <div>
    <p class="eyebrow">Admissions</p>
    <h1>Parametres</h1>
  </div>
</section>

<section class="admin-panel">
  <form action="/admin/parametres" method="post" class="stack-form">
    <label>
      <span>Date limite de depot</span>
      <input type="date" name="application_deadline" value="<%= settings.application_deadline %>" required>
    </label>
    <label>
      <span>Message admission</span>
      <textarea name="admission_message" rows="4"><%= settings.admission_message %></textarea>
    </label>
    <label>
      <span>E-mail de contact</span>
      <input type="email" name="contact_email" value="<%= settings.contact_email %>">
    </label>
    <label>
      <span>Telephone</span>
      <input name="contact_phone" value="<%= settings.contact_phone %>">
    </label>
    <label>
      <span>Adresse</span>
      <textarea name="contact_address" rows="3"><%= settings.contact_address %></textarea>
    </label>
    <button class="button" type="submit">Enregistrer les parametres</button>
  </form>
</section>

<%- include('../partials/admin-end') %>
