<%- include('../partials/admin-start') %>

<section class="admin-title">
  <div>
    <p class="eyebrow">Synthese</p>
    <h1>Tableau de bord</h1>
  </div>
  <a class="button" href="/admin/candidatures">Voir les candidatures</a>
</section>

<section class="admin-stats">
  <article>
    <span>Total dossiers</span>
    <strong><%= totalApplications %></strong>
  </article>
  <% statuses.forEach((status) => { %>
    <% const item = statusCounts.find((row) => row.status === status.value); %>
    <article>
      <span><%= status.label %></span>
      <strong><%= item ? item.total : 0 %></strong>
    </article>
  <% }) %>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2>Repartition par cycle</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Cycle</th><th>Dossiers</th></tr>
        </thead>
        <tbody>
          <% cycleCounts.forEach((row) => { %>
            <tr><td><%= row.name %></td><td><%= row.total %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>
  <article class="admin-panel">
    <h2>Derniers dossiers</h2>
    <% if (!latest.length) { %>
      <p class="empty-state">Aucune candidature enregistree.</p>
    <% } %>
    <div class="compact-list">
      <% latest.forEach((application) => { %>
        <a href="/admin/candidatures/<%= application.id %>">
          <strong><%= application.reference_number %></strong>
          <span><%= application.last_name %> <%= application.first_name %> - <%= statusLabel(application.status) %></span>
        </a>
      <% }) %>
    </div>
  </article>
</section>

<%- include('../partials/admin-end') %>
