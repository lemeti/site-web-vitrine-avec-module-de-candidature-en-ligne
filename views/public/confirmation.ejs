<%- include('../partials/site-start') %>

<section class="page-hero page-hero--confirmation">
  <p class="eyebrow">Dossier transmis</p>
  <h1>Candidature enregistree</h1>
  <p>Votre numero de dossier est :</p>
  <strong class="reference-number"><%= application.reference_number %></strong>
  <div class="hero-actions">
    <button class="button" type="button" data-print>Imprimer le recapitulatif</button>
    <a class="button button--secondary" href="/">Retour a l'accueil</a>
  </div>
</section>

<section class="section printable">
  <div class="summary-grid">
    <article class="summary-card">
      <h2>Identite</h2>
      <dl>
        <div><dt>Nom</dt><dd><%= application.last_name %></dd></div>
        <div><dt>Prenom</dt><dd><%= application.first_name %></dd></div>
        <div><dt>Naissance</dt><dd><%= formatDate(application.birth_date) %> a <%= application.birth_place %></dd></div>
        <div><dt>Contact</dt><dd><%= application.phone %> / <%= application.email %></dd></div>
      </dl>
    </article>
    <article class="summary-card">
      <h2>Candidature</h2>
      <dl>
        <div><dt>Cycle</dt><dd><%= application.cycle_name %></dd></div>
        <div><dt>Filiere</dt><dd><%= application.program_code %> - <%= application.program_name %></dd></div>
        <div><dt>Centre</dt><dd><%= application.center_name %></dd></div>
        <div><dt>Statut</dt><dd><%= statusLabel(application.status) %></dd></div>
      </dl>
    </article>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Piece</th>
          <th>Fichier transmis</th>
          <th>Taille</th>
        </tr>
      </thead>
      <tbody>
        <% documents.forEach((doc) => { %>
          <tr>
            <td><%= doc.label %></td>
            <td><%= doc.original_name %></td>
            <td><%= fileSize(doc.size) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/site-end') %>
