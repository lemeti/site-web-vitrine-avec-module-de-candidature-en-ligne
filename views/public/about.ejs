<%- include('../partials/site-start') %>

<section class="page-hero page-hero--about">
  <p class="eyebrow">Presentation generale</p>
  <h1>A propos de l'IBA</h1>
  <p>
    L'Institut Universitaire des Beaux-Arts de l'Universite de Douala a Nkongsamba
    forme des profils creatifs dans les arts, la culture, l'architecture et les metiers connexes.
  </p>
</section>

<section class="section split">
  <div>
    <h2>Mission du projet</h2>
    <p>
      Cette plateforme presente l'institut, ses filieres, ses diplomes, ses debouches
      et ses modalites d'admission. Elle propose aussi un formulaire de candidature
      statique afin de simplifier la preparation des dossiers.
    </p>
  </div>
  <div class="feature-panel">
    <h3>Objectifs specifiques</h3>
    <ul class="check-list">
      <li>Presenter l'historique, les missions et les formations.</li>
      <li>Afficher les filieres, diplomes et conditions d'admission.</li>
      <li>Permettre aux candidats de soumettre leur dossier en ligne.</li>
      <li>Fournir une experience frontend claire, responsive et facile a deployer.</li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="section-heading">
    <p class="eyebrow">Gouvernance</p>
    <h2>Parties prenantes</h2>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Partie prenante</th>
          <th>Role</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Direction de l'IBA</td><td>Validation institutionnelle du projet.</td></tr>
        <tr><td>Service de la scolarite</td><td>Reception et verification des candidatures.</td></tr>
        <tr><td>Candidats</td><td>Soumission des dossiers et consultation des informations.</td></tr>
        <tr><td>Equipe projet</td><td>Conception, developpement, tests et documentation.</td></tr>
        <tr><td>Hebergement frontend</td><td>Publication du site statique et maintenance des contenus.</td></tr>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/site-end') %>
