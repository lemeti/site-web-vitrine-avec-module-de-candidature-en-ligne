# ============================================
# Serveur IBA Nkongsamba - Variables d'environnement
# ============================================
# Copier ce fichier vers .env et adapter les valeurs
# NE PAS COMMITER le fichier .env dans Git

# Port du serveur
PORT=3000

# Environnement (development ou production)
NODE_ENV=development

# ============================================
# Base de données (à configurer plus tard)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iba_nkongsamba
DB_USER=iba_user
DB_PASSWORD=password

# ============================================
# Clé secrète pour les sessions et tokens
# ============================================
API_SECRET=votre-cle-secrete-a-changer-en-production

# ============================================
# Configuration Email (pour les notifications)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre-email@gmail.com
EMAIL_PASS=votre-mot-de-passe-app
EMAIL_FROM=noreply@iba-nkongsamba.cm

# ============================================
# Configuration des uploads
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880